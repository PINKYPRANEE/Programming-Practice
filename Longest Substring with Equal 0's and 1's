def longest_equal_01(s):
    prefix_sum = 0
    max_len = 0
    first_occurrence = {0: -1}

    for i in range(len(s)):
        if s[i] == '0':
            prefix_sum += -1
        else:
            prefix_sum += 1

        if prefix_sum in first_occurrence:
            max_len = max(max_len, i - first_occurrence[prefix_sum])
        else:
            first_occurrence[prefix_sum] = i

    return max_len


# Input
s = input().strip()

# Output
print(longest_equal_01(s))
